{
  "manifest_version": 3,
  "name": "LinkedIn Markdown Specs",
  "version": "1.1.0",
  "description": "Automatically renders markdown formatting in LinkedIn feed posts.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/feed/*",
        "https://www.linkedin.com/posts/*",
        "https://www.linkedin.com/feed/update/*"
    ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn Markdown Specs"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
